Options -MultiViews

<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs|css|woff2|png|ico|svg|webmanifest)$">
    Header always set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /basixmacro/

  # Never rewrite static asset directories
  RewriteRule ^_nuxt/ - [L]
  RewriteRule ^icons  - [L]
  RewriteRule ^fonts/ - [L]

  # Never rewrite existing files (sw.js, manifest, favicon, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback
  RewriteRule ^ index.html [L]
</IfModule>
